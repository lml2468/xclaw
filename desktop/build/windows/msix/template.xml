<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="octobuddy"
        Arguments=""
        InstallLocation="C:\Program Files\OctoBuddy\OctoBuddy">
    </Installer>
    <PackageInformation
        PackageName="OctoBuddy"
        PackageDisplayName="OctoBuddy"
        PublisherName="CN=OctoBuddy"
        PublisherDisplayName="OctoBuddy"
        Version="0.1.0.0"
        PackageDescription="OctoBuddy — agent gateway desktop">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.mlt.octobuddy.desktop"
                Description="OctoBuddy — agent gateway desktop"
                DisplayName="OctoBuddy"
                ExecutableName="octobuddy"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>OctoBuddy</DisplayName>
            <PublisherDisplayName>OctoBuddy</PublisherDisplayName>
            <Description>OctoBuddy — agent gateway desktop</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="octobuddy.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
