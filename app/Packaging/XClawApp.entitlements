<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- XClaw is a developer power-tool: it spawns the `xclawd` daemon, which in
         turn spawns coding-agent CLIs (claude/codex), reads ~/.xclaw, and opens
         local Unix sockets in the temp dir. The App Sandbox is intentionally NOT
         enabled — its container redirection and execution restrictions are
         fundamentally incompatible with spawning arbitrary user-installed CLIs
         and driving a separate daemon. The app ships hardened-runtime + Developer
         ID notarized for direct distribution (not the Mac App Store).

         We grant only the network client entitlement (the agent reaches the
         network; the local control bus is a UDS). Library validation is left at
         the hardened-runtime default: the app does not load third-party
         libraries in-process — it fork/exec's `xclawd` as a SUBPROCESS, which
         hardened runtime permits regardless of the helper's signing identity, so
         no `disable-library-validation` exception is needed. -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
